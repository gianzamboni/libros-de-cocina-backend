# --- Server ---
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# --- Database (Railway Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/libros_de_cocina?schema=public

# --- Auth ---
# Secret used to sign our app JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# The single owner account. Seeded into the DB and used as the Google allowlist.
ADMIN_EMAIL=gianfranco376@gmail.com
ADMIN_PASSWORD=change-me
# Google OAuth client id (audience) used to verify Google Sign-In ID tokens.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Image storage (Railway Volume) ---
# Directory where uploaded book covers are written. On Railway, point this
# inside the mounted volume, e.g. /data/uploads
UPLOAD_DIR=./uploads
# Max upload size in bytes (default 5 MB)
MAX_UPLOAD_BYTES=5242880

# --- Claude AI (index scanner) ---
ANTHROPIC_API_KEY=sk-ant-...
